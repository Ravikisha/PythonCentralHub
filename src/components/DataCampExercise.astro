---
export interface Props {
  /**
   * Programming language for the exercise.
   * Common values: "python".
   */
  lang?: string;

  /**
   * Code shown in the editor.
   */
  code: string;

  /**
   * Optional: code that runs before the exercise.
   */
  preExerciseCode?: string;

  /**
   * Optional: solution used by DataCamp.
   */
  solution?: string;

  /**
   * Optional: SCT (submission correctness test).
   */
  sct?: string;

  /**
   * Optional: hint text. If provided, DataCamp Light can show a "Hint" button.
   */
  hint?: string;

  /**
   * Where to render the hint. DataCamp examples often place the hint as a sibling
   * element after the <code> blocks.
   */
  hintPlacement?: "before" | "after";

  /**
  * If true (default), render the exercise inside an iframe (srcdoc) to fully
  * isolate it from the website's CSS.
   */
  isolated?: boolean;

  /**
   * Show DataCamp Light's own UI controls (Run, Hint, etc.).
   *
   * If the upstream widget doesn't expose these controls for a given
   * configuration, this won't force them to appear.
   */
  showControls?: boolean;

  /**
   * Optional: sets the exercise height.
   * Use a number (px) or "auto".
   */
  height?: number | "auto";

  /**
   * If true, show a small debug overlay inside the iframe with initialization
   * state and errors. Useful when the native toolbar buttons don't render.
   */
  debug?: boolean;

}

const {
  lang = "python",
  code,
  preExerciseCode,
  solution,
  sct,
  hint,
  hintPlacement = "after",
  isolated = true,
  showControls = true,
  height = "auto",
  debug = false,
} = Astro.props;

// A stable-ish, unique id per component instance.
const exerciseId = `dc-exercise-${Math.random().toString(36).slice(2)}`;

const escapeHtml = (value: string) =>
  value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");

const srcdoc = `<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://cdn.datacamp.com" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.datacamp.com">
    <!-- DataCamp Light UI styles (buttons/toolbar) -->
    <link rel="stylesheet" href="https://cdn.datacamp.com/dcl-react.css" />
    <style>
      /* Keep the embedded widget from inheriting any outer page styles. */
      html, body { margin: 0; padding: 0; background: transparent; }
  /* Avoid clipping the toolbar/buttons; parent iframe will resize anyway. */
  body { overflow: visible; }
      .host { width: 100%; }
    </style>

    <!-- Match the working local test.html ordering: load script (defer), then init (defer). -->
    <script defer src="//cdn.datacamp.com/dcl-react.js.gz"></script>
    <script>
window.addEventListener("DOMContentLoaded", function () {
  if (window.initAddedDCLightExercises) {
    initAddedDCLightExercises();
  }
});
</script>
  </head>
  <body>
    <div
      class="host"
      data-datacamp-exercise
      data-lang="${escapeHtml(lang)}"
  data-height="${escapeHtml(String(height))}"
  data-no-lazy-loading
  ${showControls ? "data-show-run-button=\"true\"" : ""}
  id="${escapeHtml(exerciseId)}"
    >
  ${hint && hintPlacement === "before" ? `<div data-type="hint">${escapeHtml(hint)}</div>` : ""}
      ${preExerciseCode ? `<code data-type="pre-exercise-code">${escapeHtml(preExerciseCode)}</code>` : ""}
  <code data-type="sample-code">${escapeHtml(code)}</code>
  ${solution ? `<code data-type="solution">${escapeHtml(solution)}</code>` : ""}
  ${sct ? `<code data-type="sct">${escapeHtml(sct)}</code>` : ""}
  ${hint && hintPlacement === "after" ? `<div data-type="hint">${escapeHtml(hint)}</div>` : ""}
    </div>

    <script>
      (function () {
        // Resize the iframe to the widget height.
        function postHeight() {
          try {
            // Some embedded layouts report scrollHeight too small; take the max of
            // scrollHeight/offsetHeight across body+documentElement.
            var body = document.body;
            var doc = document.documentElement;
            var h = Math.max(
              body ? body.scrollHeight : 0,
              body ? body.offsetHeight : 0,
              doc ? doc.scrollHeight : 0,
              doc ? doc.offsetHeight : 0
            );
            parent.postMessage({
              type: "pythoncentralhub-dcl-height",
              id: "${escapeHtml(exerciseId)}",
              height: h
            }, "*");
          } catch (e) {}
        }

        var mo = new MutationObserver(function () { postHeight(); });
        mo.observe(document.documentElement, { childList: true, subtree: true, attributes: true });
        window.addEventListener("load", function () { setTimeout(postHeight, 0); setTimeout(postHeight, 250); setTimeout(postHeight, 1000); });
      })();
    </script>
  </body>
</html>`;
---

<div class="datacamp-exercise-iframe" data-dcl-wrapper-id={exerciseId}>
  <iframe
    class="dcl-frame"
    title="Interactive exercise"
    sandbox="allow-scripts allow-forms allow-same-origin allow-popups"
    referrerpolicy="no-referrer"
    srcdoc={srcdoc}
    data-dcl-frame-id={exerciseId}
  />
</div>

{isolated ? (
  <script define:vars={{ exerciseId }}>
    (function () {
      function onMsg(e) {
        const data = e && e.data;
        if (!data || data.type !== "pythoncentralhub-dcl-height") return;
        const id = data.id;
        const height = Number(data.height);
        if (!id || !Number.isFinite(height) || height <= 0) return;
        const frame = document.querySelector(`iframe[data-dcl-frame-id="${exerciseId}"]`);
        if (!frame) return;
        // Allow the widget to take the full height it needs (no upper clamp).
        frame.style.height = `${Math.max(height, 240)}px`;
      }
      window.addEventListener("message", onMsg);
    })();
  </script>
) : null}

<style>
  .datacamp-exercise-iframe {
    margin: 1rem 0;
    width: 100%;
    max-width: 100%;
  }

  .dcl-frame {
    width: 100%;
    max-width: 100%;
    border: 1px solid rgba(125, 125, 125, 0.25);
    border-radius: 10px;
    background: transparent;
  /* Start with a sensible minimum; it will be resized by postMessage. */
  min-height: 300px;
  height: 300px;
  }

  /* Fallback (non-iframe) container keeps the legacy behavior. */
  .datacamp-exercise {
    margin: 1rem 0;
  }
</style>
